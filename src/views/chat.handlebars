<main class="chat-page">
  <h1 class="chat-title">Web Chat</h1>
  <h4 id="usuario" class="chat-username"></h4>

  <section class="chat-layout">
    <section class="chat-panel">
      <div class="containerChat">
        <div id="chat" class="chat-messages"></div>
        <button id="scrollBottomBtn" class="scroll-bottom-btn" type="button">Ir al ultimo mensaje</button>
      </div>

      <form id="formulario" class="chat-form">
        <input type="text" name="mensaje" id="mensaje" class="mensaje" placeholder="Escribe un mensaje...">
        <input type="submit" value="ENVIAR">
      </form>
    </section>

    <aside class="users-panel">
      <p id="usersCount" class="users-count">Usuarios conectados</p>
      <div id="usersList" class="users-list"></div>
    </aside>
  </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/index.js"></script>